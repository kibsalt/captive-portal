# Faiba WiFi Captive Portal Configuration
# Server
PORTAL_HOST=192.168.14.4
PORTAL_PORT=8280
SECRET_KEY=faiba-captive-portal-secret-change-in-production

# Admin / BRAS Credentials
ADMIN_USERNAME=jtlacs
ADMIN_PASSWORD=changeme

# Database (leave unset to use default: sqlite in ./data/)
# DATABASE_URL=sqlite:///data/captive_portal.db

# RADIUS (BRAS / AAA)
RADIUS_SERVER=172.16.37.8
RADIUS_COA_PORT=3799
RADIUS_SECRET=changeme
RADIUS_NAS_ID=faiba-guest-portal

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=http://192.168.14.4:8280/api/payment/mpesa/callback
MPESA_ENV=sandbox

# SMS (Africa's Talking)
AT_USERNAME=sandbox
AT_API_KEY=your_api_key
AT_SENDER_ID=FaibaWiFi

# Portal Settings
DEFAULT_VENUE=Two Rivers Mall
DEFAULT_LOCATION=Limuru Road, Nairobi
FREE_SESSION_MINUTES=15
FREE_SESSION_MB=50
FREE_SESSION_SPEED_KBPS=2048

# External MySQL Voucher/Billing Database
# The existing RADIUS billing DB where M-Pesa payments are stored
# Phone numbers are SHA256-hashed (254XXXXXXXXX format)
EXTERNAL_DB_HOST=127.0.0.1
EXTERNAL_DB_PORT=3306
EXTERNAL_DB_USER=radius
EXTERNAL_DB_PASSWORD=changeme
EXTERNAL_DB_NAME=radius
