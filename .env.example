# Faiba WiFi Captive Portal Configuration
# Server
PORTAL_HOST=192.168.14.4
PORTAL_PORT=8480
SECRET_KEY=faiba-captive-portal-secret-change-in-production

# Admin / BRAS Credentials
ADMIN_USERNAME=jtlacs
ADMIN_PASSWORD=changeme

# Database (leave unset to use default: sqlite in ./data/)
# DATABASE_URL=sqlite:///data/captive_portal.db

# RADIUS (BRAS / AAA)
RADIUS_SERVER=172.16.37.8
RADIUS_COA_PORT=3799
